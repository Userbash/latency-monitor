{
  "name": "esports-network-monitor",
  "private": false,
  "version": "0.0.0",
  "author": {
    "name": "Developer",
    "email": "developer@example.com"
  },
  "description": "A network monitoring tool for esports events",
  "homepage": "https://github.com/your-username/esports-network-monitor",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-username/esports-network-monitor.git"
  },
  "bugs": {
    "url": "https://github.com/your-username/esports-network-monitor/issues"
  },
  "keywords": [
    "esports",
    "network-monitor",
    "latency",
    "electron",
    "rust",
    "axum",
    "react",
    "diagnostics"
  ],
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:web\" \"npm run dev:electron\"",
    "dev:web": "vite",
    "dev:backend": "cross-env CARGO_HOME=.cargo-home cargo run --manifest-path rust-backend/Cargo.toml",
    "dev:desktop": "npm run dev:electron",
    "dev:electron": "wait-on tcp:5173 && tsc -p electron/tsconfig.json && electron .",
    "build:web": "vite build",
    "build": "tsc -b && vite build && tsc -p electron/tsconfig.json",
    "build:verified": "npm run test:prebuild && npm run build",
    "dist": "npm run build && electron-builder",
    "test": "vitest",
    "test:unit": "vitest --run",
    "test:coverage": "vitest --run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install chromium",
    "test:e2e:ci": "playwright test --reporter=line,junit --output=test-results/e2e",
    "test:backend": "cross-env CARGO_HOME=.cargo-home cargo test --manifest-path rust-backend/Cargo.toml",
    "test:prebuild": "npm run workflow:check && npm run lint && npm run test:unit && npm run test:backend",
    "test:postbuild": "node scripts/postbuild-check.mjs",
    "test:postbuild:appimage": "cross-env BUILD_TARGET=appimage npm run test:postbuild",
    "test:postbuild:win": "cross-env BUILD_TARGET=windows npm run test:postbuild",
    "qa:pipeline": "node scripts/qa-pipeline.mjs",
    "test:ci": "npm run lint && npm run test:coverage",
    "build:report": "node scripts/build-report.mjs",
    "build:report:appimage": "node scripts/build-report.mjs --command \"npm run build && npx electron-builder --publish never --linux AppImage\"",
    "docker:build": "docker compose build app-api",
    "docker:up": "docker compose up -d app-api",
    "docker:down": "docker compose down",
    "release:appimage": "bash scripts/release-appimage.sh",
    "release:win": "bash scripts/release-windows.sh",
    "release:ci:appimage": "npm run build && npx electron-builder --publish never --linux AppImage",
    "release:ci:win": "npm run build && npx electron-builder --publish never --win nsis portable",
    "debug:report": "node scripts/debug-report.mjs",
    "debug:report:quick": "node scripts/debug-report.mjs --skip-e2e",
    "debug:report:ci": "node scripts/debug-report.mjs --skip-e2e",
    "workflow:check": "node scripts/workflow-check.mjs",
    "act:list": "act -W .github/workflows/ci-cd.yml -l",
    "act:quality": "act pull_request -W .github/workflows/ci-cd.yml -j quality",
    "act:backend": "act pull_request -W .github/workflows/ci-cd.yml -j rust-backend-tests",
    "act:release:appimage": "act pull_request -W .github/workflows/ci-cd.yml -j release-builds --matrix target:appimage",
    "act:ci:local": "npm run act:quality && npm run act:backend",
    "lint": "eslint .",
    "preview": "vite preview",
    "prepare": "husky",
    "lint-staged": "lint-staged"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "eslint --fix",
      "vitest related --run"
    ]
  },
  "dependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "electron-squirrel-startup": "^1.0.1",
    "framer-motion": "^12.38.0",
    "lucide-react": "^0.577.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.58.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.0",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "jsdom": "^29.0.0",
    "lint-staged": "^16.4.0",
    "playwright": "^1.58.2",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.2",
    "ts-jest": "^29.4.6",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "execa": "^9.6.0",
    "vite": "^8.0.1",
    "vitest": "^4.1.0",
    "wait-on": "^9.0.4",
    "yaml": "^2.8.1"
  }
}
